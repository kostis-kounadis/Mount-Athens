---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Αναφορά Προβλήματος | Ορειβατικό Ημερολόγιο" footerClass="px-6 md:px-12">
  <div class="max-w-2xl mx-auto bg-white border border-slate-200 rounded-xl p-8 shadow-sm my-8">
    <h1 class="text-2xl font-bold text-slate-900 mb-2 font-sans tracking-tight">Αναφορά Προβλήματος</h1>
    <p class="text-slate-500 text-sm mb-8 font-sans">
      Βρήκατε κάποιο σφάλμα στο πρόγραμμα; Λείπει κάποια εκδρομή ή κάποιο link δεν λειτουργεί; Θέλετε να προστεθεί κάποιος ακόμα Σύλλογος; Στείλτε μας μήνυμα και ενδεχομένως να το διορθώσουμε...
    </p>

    <!-- NOTE FOR DEPLOYMENT: Replace 'YOUR_FORMSPREE_ENDPOINT_HERE' with the actual endpoint from Formspree.io -->
    <form action="https://formspree.io/f/xjgqglep" method="POST" class="space-y-6 font-sans">
      <div>
        <label for="name" class="block text-xs font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Ονομα <span class="text-orange-500">*</span></label>
        <input 
          type="text" 
          id="name" 
          name="name" 
          required
          placeholder="Πώς να σας αποκαλούμε;"
          class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:border-slate-900 focus:ring-1 focus:ring-slate-900 transition-all duration-200"
        />
      </div>

      <div>
        <label for="email" class="block text-xs font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Email <span class="text-orange-500">*</span></label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required
          placeholder="Για να μπορέσουμε να σας απαντήσουμε..."
          class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:border-slate-900 focus:ring-1 focus:ring-slate-900 transition-all duration-200"
        />
      </div>

      <div>
        <label for="message" class="block text-xs font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Το Μηνυμα σας <span class="text-orange-500">*</span></label>
        <textarea 
          id="message" 
          name="message" 
          required
          rows="5"
          placeholder="Περιγράψτε το πρόβλημα που συναντήσατε..."
          class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:border-slate-900 focus:ring-1 focus:ring-slate-900 transition-all duration-200 resize-y"
        ></textarea>
      </div>

      <!-- Honeypot Field to prevent spam bots -->
      <input type="text" name="_gotcha" class="hidden" style="display:none" />

      <div class="pt-2">
        <button 
          type="submit" 
          class="w-full sm:w-auto px-6 py-3 bg-slate-900 hover:bg-slate-800 text-white text-sm font-bold rounded-lg transition-colors duration-200 flex items-center justify-center gap-2"
        >
          <span>Αποστολή Μηνύματος</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </button>
      </div>
    </form>
  </div>
</Layout>
