---
import Layout from '../layouts/Layout.astro';
import eventsData from '../data/events.json';
import statusData from '../data/status.json';

const GREEK_MONTHS = [
  "Ιανουάριος", "Φεβρουάριος", "Μάρτιος", "Απρίλιος", "Μάιος", "Ιούνιος",
  "Ιούλιος", "Αύγουστος", "Σεπτέμβριος", "Οκτώβριος", "Νοέμβριος", "Δεκέμβριος"
];

const GREEK_DAYS_FULL = ["ΚΥΡΙΑΚΗ", "ΔΕΥΤΕΡΑ", "ΤΡΙΤΗ", "ΤΕΤΑΡΤΗ", "ΠΕΜΠΤΗ", "ΠΑΡΑΣΚΕΥΗ", "ΣΑΒΒΑΤΟ"];
const GREEK_MONTHS_FULL = [
  "ΙΑΝΟΥΑΡΙΟΥ", "ΦΕΒΡΟΥΑΡΙΟΥ", "ΜΑΡΤΙΟΥ", "ΑΠΡΙΛΙΟΥ", "ΜΑΪΟΥ", "ΙΟΥΝΙΟΥ",
  "ΙΟΥΛΙΟΥ", "ΑΥΓΟΥΣΤΟΥ", "ΣΕΠΤΕΜΒΡΙΟΥ", "ΟΚΤΩΒΡΙΟΥ", "ΝΟΕΜΒΡΙΟΥ", "ΔΕΚΕΜΒΡΙΟΥ"
];

// Club styling themes for Light Theme
const CLUB_THEMES: Record<string, { badge: string; border: string; active: string; dot: string }> = {
  'ΕΟΣ Αθηνών': {
    badge: 'bg-rose-50/50 text-rose-700 border-rose-200/60',
    border: 'hover:border-rose-300',
    dot: 'bg-rose-500',
    active: 'bg-rose-900 border-rose-950 text-white ring-2 ring-rose-900/10'
  },
  'ΑΟΣ': {
    badge: 'bg-emerald-50/50 text-emerald-700 border-emerald-200/60',
    border: 'hover:border-emerald-300',
    dot: 'bg-emerald-500',
    active: 'bg-emerald-900 border-emerald-950 text-white ring-2 ring-emerald-900/10'
  },
  'ΠΟΑ': {
    badge: 'bg-amber-50/50 text-amber-800 border-amber-200/60',
    border: 'hover:border-amber-300',
    dot: 'bg-amber-500',
    active: 'bg-amber-800 border-amber-900 text-white ring-2 ring-amber-800/10'
  },
  'ΕΟΣ Αχαρνών': {
    badge: 'bg-sky-50/50 text-sky-700 border-sky-200/60',
    border: 'hover:border-sky-300',
    dot: 'bg-sky-500',
    active: 'bg-sky-900 border-sky-950 text-white ring-2 ring-sky-900/10'
  },
  'ΕΟΣ Ηλιούπολης': {
    badge: 'bg-indigo-50/50 text-indigo-700 border-indigo-200/60',
    border: 'hover:border-indigo-300',
    dot: 'bg-indigo-500',
    active: 'bg-indigo-900 border-indigo-950 text-white ring-2 ring-indigo-900/10'
  },
  'ΦΟΝΙ': {
    badge: 'bg-orange-50/50 text-orange-700 border-orange-200/60',
    border: 'hover:border-orange-300',
    dot: 'bg-orange-500',
    active: 'bg-orange-800 border-orange-900 text-white ring-2 ring-orange-800/10'
  },
  'ΕΠΟΣ Φυλής': {
    badge: 'bg-pink-50/50 text-pink-700 border-pink-200/60',
    border: 'hover:border-pink-300',
    dot: 'bg-pink-500',
    active: 'bg-pink-900 border-pink-950 text-white ring-2 ring-pink-900/10'
  }
};

const defaultTheme = {
  badge: 'bg-slate-50 text-slate-600 border-slate-200/60',
  border: 'hover:border-slate-300',
  dot: 'bg-slate-400',
  active: 'bg-slate-800 border-slate-900 text-white ring-2 ring-slate-800/10'
};

// Group events by month & year first
const groupedEvents = eventsData.reduce((acc: Record<string, typeof eventsData>, event) => {
  const date = new Date(event.startDate);
  const monthName = GREEK_MONTHS[date.getMonth()];
  const year = date.getFullYear();
  const groupKey = `${monthName} ${year}`;
  
  if (!acc[groupKey]) {
    acc[groupKey] = [];
  }
  acc[groupKey].push(event);
  return acc;
}, {});

// Nested grouping: Group each month's events by their exact startDate
const groupedByMonthAndDate = Object.entries(groupedEvents).reduce((acc: Record<string, Record<string, typeof eventsData>>, [monthYear, events]) => {
  const dateGroups = events.reduce((dAcc: Record<string, typeof eventsData>, event) => {
    const dateKey = event.startDate;
    if (!dAcc[dateKey]) {
      dAcc[dateKey] = [];
    }
    dAcc[dateKey].push(event);
    return dAcc;
  }, {});
  
  acc[monthYear] = dateGroups;
  return acc;
}, {});

const totalEvents = eventsData.length;
const uniqueClubs = [...new Set(eventsData.map(e => e.club))];
---

<Layout>
  
  <!-- Minimal Compact Filters Dashboard -->
  <div class="bg-white border border-slate-200 rounded-xl p-5 mb-8 shadow-sm">
    <div class="flex flex-col gap-4">
      <!-- Row 1: Search & Total count -->
      <div class="flex flex-col sm:flex-row gap-4 items-stretch sm:items-center justify-between pb-4 border-b border-slate-100">
        <div class="relative flex-grow max-w-lg">
          <input 
            type="text" 
            id="search-input" 
            placeholder="Αναζήτηση βουνού, προορισμού (π.χ. Ταΰγετος)..." 
            class="w-full pl-3 pr-8 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm placeholder-slate-400 focus:outline-none focus:border-slate-900 focus:bg-white transition-all duration-200 font-sans"
          />
          <button 
            id="clear-search-btn" 
            class="absolute inset-y-0 right-0 pr-2.5 flex items-center text-slate-400 hover:text-slate-600 hidden"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="flex items-center gap-2 text-mono text-xs text-slate-500 self-end sm:self-auto select-none">
          <span>ΒΡΕΘΗΚΑΝ:</span>
          <span class="font-bold text-slate-900 bg-slate-100 border border-slate-200 px-2 py-0.5 rounded text-mono" id="stat-total-count">{totalEvents}</span>
        </div>
      </div>

      <!-- Row 2: Club Filter pills -->
      <div>
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block mb-2 select-none font-mono">ΣΥΛΛΟΓΟΣ:</span>
        <div class="flex flex-wrap gap-1.5" id="club-filters-container">
          <button 
            data-club-filter="all" 
            class="px-2.5 py-1 rounded border border-slate-900 bg-slate-900 text-white text-xs font-semibold font-sans transition-all duration-200 active-club-btn"
          >
            Όλοι ({totalEvents})
          </button>
          {uniqueClubs.map(club => {
            const count = eventsData.filter(e => e.club === club).length;
            const theme = CLUB_THEMES[club] || defaultTheme;
            return (
              <button
                data-club-filter={club}
                data-active-class={theme.active}
                data-inactive-class={`${theme.badge} ${theme.border} text-slate-600 hover:bg-slate-100`}
                class={`px-2.5 py-1 rounded border text-xs font-semibold font-sans ${theme.badge} ${theme.border} transition-all duration-200`}
              >
                {club} ({count})
              </button>
            )
          })}
        </div>
      </div>
    </div>
  </div>

  <!-- Calendar Content -->
  <div class="space-y-10" id="calendar-container">
    {Object.keys(groupedByMonthAndDate).map(monthYear => {
      const dateGroups = groupedByMonthAndDate[monthYear];
      return (
        <div class="month-group" data-month-year={monthYear}>
          <!-- Minimal Month Separator -->
          <h2 class="text-mono text-xs font-bold tracking-widest text-slate-400 mt-10 mb-5 uppercase select-none">
            {monthYear}
          </h2>

          <!-- Date-Grouped Calendar Card -->
          <div class="bg-white border border-slate-200 rounded-xl divide-y divide-slate-200 shadow-sm overflow-hidden">
            {Object.keys(dateGroups).map(dateStr => {
              const events = dateGroups[dateStr];
              const d = new Date(dateStr);
              const dayNum = d.getDate();
              const dayOfWeek = GREEK_DAYS_FULL[d.getDay()];
              const monthFull = GREEK_MONTHS_FULL[d.getMonth()];
              
              return (
                <div class="date-group flex flex-col md:flex-row items-stretch" data-date={dateStr}>
                  <!-- Date Column (Left) -->
                  <div class="w-full md:w-28 bg-slate-50/40 md:border-r border-slate-200 p-4 flex flex-row md:flex-col items-baseline md:items-start justify-between md:justify-start gap-2 select-none font-mono flex-shrink-0">
                    <span class="text-3xl font-bold text-slate-800 leading-none">
                      {dayNum}
                    </span>
                    <div class="flex md:flex-col items-baseline md:items-start gap-1.5 md:gap-0.5 text-[9px] text-slate-400 font-bold tracking-wider font-mono">
                      <span>{dayOfWeek}</span>
                      <span class="md:hidden">/</span>
                      <span>{monthFull}</span>
                    </div>
                  </div>

                  <!-- Events List (Right) -->
                  <div class="flex-grow p-4 md:p-5 space-y-4 event-rows-container">
                    {events.map((event, idx) => {
                      const theme = CLUB_THEMES[event.club] || defaultTheme;
                      const isMultiDay = event.startDate !== event.endDate;
                      
                      const searchText = `${event.title} ${event.club} ${monthYear} ${isMultiDay ? 'πολυήμερο' : 'μονοήμερο'}`;
                      
                      return (
                        <div 
                          class={`event-row flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-2.5 first:pt-0 last:pb-0 ${idx > 0 ? 'border-t border-slate-200/80 pt-4 mt-4' : ''}`}
                          data-club={event.club}
                          data-search-text={searchText}
                        >
                          <!-- Title & Meta Tags -->
                          <div class="flex-grow min-w-0 pr-0 sm:pr-4">
                            <!-- Event Title (IBM Plex Sans) on TOP -->
                            <h3 class="text-sm font-semibold text-slate-900 leading-snug mb-2 font-sans">
                              <a 
                                href={event.url} 
                                target="_blank" 
                                rel="noopener noreferrer" 
                                class="hover:text-slate-500 transition-colors duration-150"
                              >
                                {event.title}
                              </a>
                            </h3>

                            <div class="flex flex-wrap items-center gap-1.5">
                              <!-- Club Name Badge (Fixed 22px Height) -->
                              <button 
                                type="button"
                                data-filter-club={event.club}
                                class={`inline-flex items-center h-[22px] px-2 border text-[9px] uppercase font-bold tracking-wider font-mono rounded cursor-pointer transition-colors duration-150 ${theme.badge} ${theme.border}`}
                                title={`Φιλτράρισμα κατά ${event.club}`}
                              >
                                {event.club}
                              </button>

                              <!-- Excursion date tag if multi-day (Fixed 22px Height) -->
                              {isMultiDay && (
                                <span class="inline-flex items-center h-[22px] px-2 border border-slate-200 text-[9px] font-bold font-mono text-slate-400 bg-slate-50 rounded select-none">
                                  {event.displayDate}
                                </span>
                              )}
                            </div>
                          </div>

                          <!-- Action Booking details link -->
                          <div class="flex-shrink-0 self-start sm:self-auto">
                            <a 
                              href={event.url}
                              target="_blank" 
                              rel="noopener noreferrer" 
                              class="inline-flex items-center gap-1 text-mono text-xs font-semibold text-slate-800 hover:text-slate-500 transition-colors duration-150"
                            >
                              Λεπτομέρειες
                              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                            </a>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      );
    })}

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-16 bg-white border border-slate-200 rounded-xl max-w-md mx-auto shadow-sm">
      <h3 class="text-slate-800 text-sm font-bold mb-1 font-sans">Δεν βρέθηκαν εκδρομές</h3>
      <p class="text-slate-400 text-xs font-light mb-5 px-6 leading-relaxed font-sans">
        Δεν υπάρχουν εξορμήσεις που να ταιριάζουν με τα φίλτρα σας. Δοκιμάστε να καθαρίσετε την αναζήτηση.
      </p>
      <button 
        id="reset-filters-btn" 
        class="px-4 py-2 bg-slate-900 text-white text-xs font-bold rounded-lg hover:bg-slate-800 transition-colors"
      >
        Επαναφορά Φίλτρων
      </button>
    </div>

    <!-- Collapsible System Status Logs Panel -->
    <div class="mt-12 border border-slate-200 rounded-xl bg-white shadow-sm overflow-hidden select-none">
      <button 
        id="status-panel-toggle" 
        class="w-full flex items-center justify-between px-5 py-4 text-left font-mono text-[10px] font-bold tracking-wider text-slate-500 hover:bg-slate-50 focus:outline-none transition-colors duration-150"
      >
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
          <span>ΚΑΤΑΣΤΑΣΗ ΣΥΓΧΡΟΝΙΣΜΟΥ (STATUS LOGS)</span>
        </div>
        <svg id="status-panel-chevron" class="w-3 h-3 transform transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <div id="status-panel-content" class="hidden border-t border-slate-100 p-5 bg-slate-50/30 font-mono text-[9px] text-slate-500 space-y-3">
        <div class="flex items-center justify-between pb-2 border-b border-slate-100">
          <span>ΤΕΛΕΥΤΑΙΑ ΕΝΗΜΕΡΩΣΗ:</span>
          <span class="font-bold text-slate-800">{new Date(statusData.lastUpdated).toLocaleString('el-GR', { timeZone: 'Europe/Athens' })}</span>
        </div>
        <div class="space-y-2.5">
          {statusData.logs.map(log => (
            <div class="border-b border-slate-100 pb-2.5 last:border-0 last:pb-0">
              <div class="flex items-center justify-between">
                <span class="font-semibold text-slate-700">{log.club}:</span>
                <div class="flex items-center gap-1.5">
                  <span class={`w-1 h-1 rounded-full ${log.status === 'success' ? 'bg-emerald-500' : 'bg-rose-500'}`}></span>
                  <span class={log.status === 'success' ? 'text-slate-600' : 'text-rose-600 font-medium'}>{log.details}</span>
                </div>
              </div>
              {log.fetch && (
                <div class="mt-1 pl-3 text-[8px] text-slate-400 space-y-0.5 font-mono">
                  {log.fetch.map((f: any) => (
                    <div class="flex items-center justify-between gap-4">
                      <span class="truncate max-w-[280px]" title={f.url}>{f.url}</span>
                      <span class={f.success ? 'text-slate-500' : 'text-rose-500 font-medium'}>
                        {f.success ? `${(f.size/1024).toFixed(1)} KB (HTTP ${f.code})` : `Failed: ${f.status}`}
                      </span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Client-side filtering script -->
  <script>
    // Toggle Status Logs Panel
    const statusPanelToggle = document.getElementById('status-panel-toggle');
    const statusPanelContent = document.getElementById('status-panel-content');
    const statusPanelChevron = document.getElementById('status-panel-chevron');
    
    if (statusPanelToggle && statusPanelContent && statusPanelChevron) {
      statusPanelToggle.addEventListener('click', () => {
        const isHidden = statusPanelContent.classList.contains('hidden');
        if (isHidden) {
          statusPanelContent.classList.remove('hidden');
          statusPanelChevron.classList.add('rotate-180');
        } else {
          statusPanelContent.classList.add('hidden');
          statusPanelChevron.classList.remove('rotate-180');
        }
      });
    }

    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const clearSearchBtn = document.getElementById('clear-search-btn') as HTMLButtonElement;
    const clubFiltersContainer = document.getElementById('club-filters-container');
    
    const eventRows = document.querySelectorAll('.event-row');
    const dateGroups = document.querySelectorAll('.date-group');
    const monthGroups = document.querySelectorAll('.month-group');
    const emptyState = document.getElementById('empty-state');
    const resetFiltersBtn = document.getElementById('reset-filters-btn');
    const statTotalCount = document.getElementById('stat-total-count');

    let activeClub = 'all';
    let searchQuery = '';

    // Greek Accent Normalizer
    function cleanString(str: string): string {
      return str
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[άά]/g, 'a')
        .replace(/[έέ]/g, 'e')
        .replace(/[ήή]/g, 'i')
        .replace(/[ίίϊΐ]/g, 'i')
        .replace(/[όό]/g, 'o')
        .replace(/[υύϋΰ]/g, 'y')
        .replace(/[ώώ]/g, 'o');
    }

    function applyFilters() {
      let visibleCount = 0;
      const cleanQuery = cleanString(searchQuery);

      // Filter rows
      eventRows.forEach(row => {
        const rowElement = row as HTMLElement;
        const clubVal = rowElement.getAttribute('data-club') || '';
        const searchRaw = rowElement.getAttribute('data-search-text') || '';
        const cleanSearchText = cleanString(searchRaw);

        const clubMatches = (activeClub === 'all' || clubVal === activeClub);
        const searchMatches = (cleanQuery === '' || cleanSearchText.includes(cleanQuery));

        if (clubMatches && searchMatches) {
          rowElement.classList.remove('hidden');
          visibleCount++;
        } else {
          rowElement.classList.add('hidden');
        }
      });

      // Filter Date Groups
      dateGroups.forEach(dg => {
        const dgElement = dg as HTMLElement;
        const visibleRowsInDg = dgElement.querySelectorAll('.event-row:not(.hidden)');
        
        if (visibleRowsInDg.length === 0) {
          dgElement.classList.add('hidden');
        } else {
          dgElement.classList.remove('hidden');
          
          // Re-add top borders dynamically for visible items inside the date group
          visibleRowsInDg.forEach((row, idx) => {
            const rowElement = row as HTMLElement;
            if (idx === 0) {
              rowElement.classList.remove('border-t', 'border-slate-200/80', 'pt-4', 'mt-4');
            } else {
              rowElement.classList.add('border-t', 'border-slate-200/80', 'pt-4', 'mt-4');
            }
          });
        }
      });

      // Filter Month Groups
      monthGroups.forEach(mg => {
        const mgElement = mg as HTMLElement;
        const visibleDateGroups = mgElement.querySelectorAll('.date-group:not(.hidden)');
        
        if (visibleDateGroups.length === 0) {
          mgElement.classList.add('hidden');
        } else {
          mgElement.classList.remove('hidden');
        }
      });

      // Update counters
      if (statTotalCount) statTotalCount.textContent = visibleCount.toString();

      // Toggle Empty State
      if (visibleCount === 0) {
        if (emptyState) emptyState.classList.remove('hidden');
      } else {
        if (emptyState) emptyState.classList.add('hidden');
      }
    }

    // Search Input listeners
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value;
        if (searchQuery.trim() !== '') {
          if (clearSearchBtn) clearSearchBtn.classList.remove('hidden');
        } else {
          if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
        }
        applyFilters();
      });
    }

    if (clearSearchBtn) {
      clearSearchBtn.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        searchQuery = '';
        clearSearchBtn.classList.add('hidden');
        applyFilters();
      });
    }

    // Club selection filters
    if (clubFiltersContainer) {
      clubFiltersContainer.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const button = target.closest('[data-club-filter]') as HTMLButtonElement;
        if (!button) return;

        const selectedClub = button.getAttribute('data-club-filter') || 'all';
        activeClub = selectedClub;

        const allButtons = clubFiltersContainer.querySelectorAll('[data-club-filter]');
        allButtons.forEach(btn => {
          const b = btn as HTMLButtonElement;
          const clubAttr = b.getAttribute('data-club-filter');
          const isAll = clubAttr === 'all';
          const activeClass = b.getAttribute('data-active-class') || '';
          const inactiveClass = b.getAttribute('data-inactive-class') || '';

          if (isAll) {
            b.className = 'px-2.5 py-1 rounded border text-xs font-semibold font-sans transition-all duration-200';
            if (activeClub === 'all') {
              b.classList.add('bg-slate-900', 'border-slate-900', 'text-white', 'active-club-btn');
            } else {
              b.classList.add('bg-white', 'border-slate-200', 'text-slate-600', 'hover:bg-slate-50');
            }
          } else {
            b.className = 'px-2.5 py-1 rounded border text-xs font-semibold font-sans transition-all duration-200';
            if (activeClub === clubAttr) {
              activeClass.split(' ').forEach(c => { if (c) b.classList.add(c); });
              b.classList.add('active-club-btn');
            } else {
              inactiveClass.split(' ').forEach(c => { if (c) b.classList.add(c); });
            }
          }
        });

        applyFilters();
      });
    }

    // Reset filters
    function resetFilters() {
      activeClub = 'all';
      searchQuery = '';
      if (searchInput) searchInput.value = '';
      if (clearSearchBtn) clearSearchBtn.classList.add('hidden');

      const allClubBtn = document.querySelector('[data-club-filter="all"]') as HTMLButtonElement;
      if (allClubBtn) allClubBtn.click();

      applyFilters();
    }

    if (resetFiltersBtn) {
      resetFiltersBtn.addEventListener('click', resetFilters);
    }

    // Inline club badge click filter
    document.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;
      
      const badge = target.closest('[data-filter-club]');
      if (!badge) return;

      const selectedClub = badge.getAttribute('data-filter-club');
      if (!selectedClub) return;

      const filterButton = document.querySelector(`[data-club-filter="${selectedClub}"]`);
      if (filterButton instanceof HTMLButtonElement) {
        filterButton.click();
        
        // Scroll smoothly back to the top of the calendar
        const container = document.getElementById('search-input');
        if (container) {
          container.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
    });
  </script>
</Layout>
