---
import SEO from '../components/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;

// Format current date in Greek (Athens timezone)
let formattedDate = '';
try {
  const parts = new Intl.DateTimeFormat('el-GR', {
    timeZone: 'Europe/Athens',
    weekday: 'long',
    day: '2-digit',
    month: 'long',
    year: 'numeric'
  }).formatToParts(new Date());

  const day = parts.find(p => p.type === 'weekday').value.toUpperCase();
  const date = parts.find(p => p.type === 'day').value;
  const month = parts.find(p => p.type === 'month').value.toUpperCase();
  const year = parts.find(p => p.type === 'year').value;
  
  const rawDate = `${day}, ${date} ${month} ${year}`;
  
  // Strip Greek accents from uppercase letters for standard Greek typography
  formattedDate = rawDate
    .replace(/Ά/g, 'Α')
    .replace(/Έ/g, 'Ε')
    .replace(/Ή/g, 'Η')
    .replace(/Ί/g, 'Ι')
    .replace(/Ό/g, 'Ο')
    .replace(/Ύ/g, 'Υ')
    .replace(/Ώ/g, 'Ω')
    .replace(/Ϋ/g, 'Υ')
    .replace(/Ϊ/g, 'Ι');
} catch (e) {
  // Safe fallback
  formattedDate = 'ΤΕΤΑΡΤΗ, 10 ΙΟΥΝΙΟΥ 2026';
}
---

<!doctype html>
<html lang="el" class="scroll-smooth">
  <head>
    <SEO title={title} description={description} image={image} />
    <style is:global>
      :root {
        --color-bg: #f8fafc; /* Slate 50 */
        --color-surface: #ffffff;
        --color-border: #e2e8f0; /* Slate 200 */
        --color-text: #0f172a; /* Slate 900 */
        --color-text-muted: #64748b; /* Slate 500 */
        --color-accent: #0f172a;
        --font-sans: 'IBM Plex Sans', sans-serif;
        --font-mono: 'IBM Plex Mono', monospace;
      }

      /* Custom scrollbar styling */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--color-bg);
      }
      ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
      }

      html {
        overflow-y: scroll;
      }
      body {
        font-family: var(--font-sans);
        background-color: var(--color-bg);
        color: var(--color-text);
        min-height: 100vh;
        overflow-x: hidden;
      }

      button, input, select, textarea {
        font-family: inherit;
      }

      .text-mono {
        font-family: var(--font-mono);
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col justify-between selection:bg-slate-200 selection:text-slate-800">

    <!-- Global Header -->
    <header class="sticky top-0 z-50 bg-white border-b border-slate-200 py-5 md:py-6 px-6 md:px-12 flex items-center justify-between shadow-sm">
      <a href={import.meta.env.BASE_URL} class="flex items-center gap-2.5 group focus:outline-none">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-slate-900 group-hover:scale-110 transition-transform duration-200" viewBox="0 0 24 24">
          <path d="m8 3 4 8 5-5 5 15H2L8 3z" />
        </svg>
        <span class="font-bold tracking-tight text-lg text-slate-900 font-sans leading-tight flex items-center gap-2">
          Ορειβατικό Ημερολόγιο
          <span class="text-[10px] font-light text-orange-500 uppercase tracking-widest px-1.5 py-0.5 border border-orange-200 rounded-md bg-orange-50/50 select-none">BETA</span>
        </span>
      </a>
      
      <div id="current-date" class="text-mono text-[10px] md:text-[11px] font-medium tracking-wider text-slate-600 select-none whitespace-nowrap ml-4">
        {formattedDate}
      </div>

      <script is:inline>
        try {
          const parts = new Intl.DateTimeFormat('el-GR', {
            timeZone: 'Europe/Athens',
            weekday: 'long',
            day: '2-digit',
            month: 'long',
            year: 'numeric'
          }).formatToParts(new Date());
          
          const day = parts.find(p => p.type === 'weekday').value.toUpperCase();
          const date = parts.find(p => p.type === 'day').value;
          const month = parts.find(p => p.type === 'month').value.toUpperCase();
          const year = parts.find(p => p.type === 'year').value;
          
          const rawDate = `${day}, ${date} ${month} ${year}`;
          const cleanDate = rawDate
            .replace(/Ά/g, 'Α')
            .replace(/Έ/g, 'Ε')
            .replace(/Ή/g, 'Η')
            .replace(/Ί/g, 'Ι')
            .replace(/Ό/g, 'Ο')
            .replace(/Ύ/g, 'Υ')
            .replace(/Ώ/g, 'Ω')
            .replace(/Ϋ/g, 'Υ')
            .replace(/Ϊ/g, 'Ι');
          
          document.getElementById('current-date').textContent = cleanDate;
        } catch (e) {
          console.error('Error setting Athens local date:', e);
        }
      </script>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow max-w-5xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
      <slot />
    </main>

    <!-- Global Footer -->
    <footer class="border-t border-slate-200 bg-white py-8 text-[11px] text-slate-500 flex-shrink-0">
      <div class="max-w-5xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href={import.meta.env.BASE_URL} class="font-mono text-slate-600 uppercase tracking-widest text-center sm:text-left hover:text-slate-900 transition-colors">
          ΟΡΕΙΒΑΤΙΚΟ ΗΜΕΡΟΛΟΓΙΟ
        </a>
        <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-5 font-mono">
          <a href={import.meta.env.BASE_URL + "info"} class="hover:underline transition-all hover:text-slate-900">ΠΛΗΡΟΦΟΡΙΕΣ</a>
          <span class="text-slate-300">/</span>
          <a href={import.meta.env.BASE_URL + "report"} class="hover:underline transition-all hover:text-slate-900">ΑΝΑΦΟΡΑ ΠΡΟΒΛΗΜΑΤΟΣ</a>
          <span class="text-slate-300">/</span>
          <a href="https://github.com/kostis-kounadis/Mount-Athens" target="_blank" rel="noopener noreferrer" class="hover:underline transition-all hover:text-slate-900">GITHUB</a>
          <span class="text-slate-300">/</span>
          <span class="font-bold text-slate-800">v1.0.0</span>
        </div>
      </div>
    </footer>
  </body>
</html>
